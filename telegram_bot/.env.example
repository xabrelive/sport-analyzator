# =============================================================================
# PingWin Telegram Bot — переменные окружения (.env)
# Скопируйте в .env и заполните. Бот выдаёт код для регистрации на сайте.
# =============================================================================

# Токен бота от @BotFather (обязательно). Тот же токен должен быть в backend .env как TELEGRAM_BOT_TOKEN.
TELEGRAM_BOT_TOKEN=

# URL бэкенда для запроса кода регистрации. В Docker: http://backend:11001
# Локально: http://localhost:11001
BACKEND_URL=http://localhost:11001

# Имя бота без @ — для отображения в сообщениях и ссылке на сайт (опционально)
# TELEGRAM_BOT_USERNAME=PingWinBot

# URL сайта для ссылок в сообщениях пользователям (регистрация, настройки).
# Должен быть публичный домен (https://pingwin.pro), не localhost.
# Приоритет: FRONTEND_PUBLIC_URL > FRONTEND_URL. Если localhost — подставляется pingwin.pro.
# FRONTEND_PUBLIC_URL=https://pingwin.pro
# FRONTEND_URL=https://pingwin.pro

# =============================================================================
# PingWin Backend — переменные окружения (.env)
# Скопируйте в .env и заполните значения.
# =============================================================================

# --- База данных (PostgreSQL) ---
# Строка подключения. Для миллионов строк и 200–2000 записей/день PostgreSQL оптимален.
# Формат: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://pingwin:pingwin@localhost:11002/pingwin

# Асинхронный URL (если не задан — строится из DATABASE_URL с драйвером asyncpg)
# DATABASE_URL_ASYNC=postgresql+asyncpg://pingwin:pingwin@localhost:11002/pingwin

# --- Секреты и JWT ---
# Секретный ключ для подписи JWT. Обязательно смените в продакшене.
SECRET_KEY=change-me-in-production-min-32-chars

# Алгоритм JWT (обычно HS256)
JWT_ALGORITHM=HS256

# Время жизни access-токена в минутах (например 10080 = 7 дней)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- Коды подтверждения ---
# Время жизни кода подтверждения (email и Telegram) в минутах
VERIFICATION_CODE_EXPIRE_MINUTES=15

# Длина кода (цифры). 6 — типичный вариант
VERIFICATION_CODE_LENGTH=6

# --- Фронтенд (для редиректов и ссылок в письмах) ---
# URL фронта при разработке
FRONTEND_URL=http://localhost:11000

# Публичный URL для продакшена (например https://pingwin.pro). Если задан — используется в письмах и редиректах.
# FRONTEND_PUBLIC_URL=https://pingwin.pro

# --- CORS ---
# Дополнительные разрешённые origins через запятую (например http://192.168.1.10:11000)
# CORS_EXTRA_ORIGINS=

# --- Режим отладки ---
# true — подробные ошибки и логи SQL
# DEBUG=false

# --- SMTP (отправка кодов на почту) ---
# Без SMTP коды только логируются, письма не отправляются.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Адрес отправителя (From)
SMTP_FROM_EMAIL=
# Использовать TLS (обычно true для порта 587)
SMTP_USE_TLS=true

# --- Telegram Bot (коды для регистрации/привязки) ---
# Токен бота от @BotFather. Нужен для: 1) отправки кода пользователю в ЛС; 2) проверки запросов от бота (X-Bot-Token).
TELEGRAM_BOT_TOKEN=
# Имя бота без @ (для ссылок типа t.me/BotName)
TELEGRAM_BOT_USERNAME=

# --- API ---
# Префикс API v1
API_V1_PREFIX=/api/v1

# Порт приложения (для uvicorn)
# PORT=11001

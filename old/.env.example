# Database
POSTGRES_USER=sport
POSTGRES_PASSWORD=sport
POSTGRES_DB=sport_analyzator
DATABASE_URL=postgresql://sport:sport@localhost:11002/sport_analyzator

# Redis
REDIS_URL=redis://localhost:11003/0

# Backend
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ADMIN_SECRET=
API_V1_PREFIX=/api/v1
DEBUG=1
# For email verification link and redirects. Локально: http://localhost:11000. Продакшен: https://pingwin.pro
FRONTEND_URL=http://localhost:11000
# Ссылки в TG и письмах (если задано — подставляется вместо FRONTEND_URL). Продакшен: https://pingwin.pro
FRONTEND_PUBLIC_URL=
# CORS: доп. origins через запятую (LAN или продакшен-домен, если фронт на другом поддомене)
# Пример LAN: http://192.168.31.130:11000,http://192.168.31.130:3000
# Пример продакшен (один домен): https://pingwin.pro
CORS_EXTRA_ORIGINS=

# Data providers (get keys from dashboards)
SPORTRADAR_API_KEY=
SPORTMONKS_API_KEY=
THE_ODDS_API_KEY=
# BetsAPI — настольный теннис: https://betsapi.com/c/table-tennis/
# Токен купить/включить: https://betsapi.com/mm/orders (лимит 3600 запросов/час)
# Для загрузки линии на сайте нужны: BETSAPI_TOKEN и ENABLE_SCHEDULED_COLLECTORS=true
BETSAPI_TOKEN=
BETSAPI_TABLE_TENNIS_SPORT_ID=92
# Сколько матчей за цикл запрашивать коэффициенты (1 запрос на матч). Лимит 3600/час.
BETSAPI_MAX_EVENTS_FOR_ODDS=50

# Telegram — бот для авторизации (Login Widget) и рассылки сигналов подписчикам
# Токен: @BotFather -> /newbot или /token
TELEGRAM_BOT_TOKEN=
# Имя бота без @ (для привязки по коду и ссылке: t.me/ИМЯ). Рекомендуется @pingwinbetsbot — только для личных уведомлений, в каналы не добавлять.
TELEGRAM_BOT_USERNAME=pingwinbetsbot
# Опционально: каналы для массовой рассылки (ID чата/канала или @username). Бот должен быть админом.
# Бесплатные сигналы — в этот чат/канал
TELEGRAM_SIGNALS_CHAT_ID=-1001642470199

# Платный канал — супергруппа/канал: бот должен быть админом с правом создавать инвайт-ссылки и банить (добавление/удаление подписчиков при оплате и истечении)
TELEGRAM_SIGNALS_PAID_CHAT_ID=-1001975944266


# Бесплатный канал: пока не отправляем (FREE_CHANNEL_ENABLED=false). При true — до 3–4 прогнозов в сутки: кф ≤2, до начала матча ≥60 мин, уверенность ~100%, окно 9–21 МСК, между сообщениями ≥1 ч.
# FREE_CHANNEL_ENABLED=false
# FREE_CHANNEL_MAX_PER_DAY=4
# FREE_CHANNEL_MIN_CONFIDENCE_PCT=98
# FREE_CHANNEL_MAX_ODDS=2
# FREE_CHANNEL_MIN_MINUTES_BEFORE_START=60
# FREE_CHANNEL_WINDOW_START_HOUR_MSK=9
# FREE_CHANNEL_WINDOW_END_HOUR_MSK=21
# FREE_CHANNEL_MIN_INTERVAL_MINUTES=60

# Личные сообщения — пользователям с подпиской на сигналы и включёнными уведомлениями в профиле (авторизованы в боте)
# Frontend: в frontend/.env.local — NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=..., NEXT_PUBLIC_TELEGRAM_BOT_LINK=...
# В BotFather: /setdomain для домена авторизации

# Email (SMTP) — рассылка сигналов и писем верификации. Если не задано — только логирование
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Биллинг (YooKassa). Без настроек кнопка «Оплатить» вернёт ошибку; для тестов можно ENABLE_DEMO_GRANT=true
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Опционально: секрет для проверки подписи вебхука (в кабинете YooKassa указать URL: https://ваш-бэкенд/api/v1/billing/webhook/yookassa)
YOOKASSA_WEBHOOK_SECRET=
# Куда вернуть пользователя после оплаты (тот же домен, что и фронт)
BILLING_RETURN_URL=https://pingwin.pro/pricing?paid=1
BILLING_SUCCESS_PATH=/pricing?paid=1
# true = выдавать подписку по POST /me/subscriptions без оплаты (только для разработки)
ENABLE_DEMO_GRANT=false

# Probability / Value
VALUE_EV_THRESHOLD=0.05
MIN_ODDS=1.01
MAX_ODDS=50.0

# Frontend (Next.js): куда проксировать /api/*. При локальном запуске фронта (npm run dev):
# — если бэкенд на порту 11001: ничего не задавать или BACKEND_URL=http://localhost:11001
# — если бэкенд на другом порту: BACKEND_PORT=11001 или BACKEND_URL=http://localhost:11001
# В Docker фронт использует BACKEND_URL=http://backend:11001 из docker-compose.
# BACKEND_PORT=
# BACKEND_URL=http://localhost:11001

# Polling (seconds). Live list every 2–3s for real-time set score; live odds every 30s for fresher coefficients.
LIVE_POLL_INTERVAL_SECONDS=3
LIVE_ODDS_POLL_INTERVAL_SECONDS=30
PREMATCH_POLL_INTERVAL_SECONDS=900

# BetsAPI archive (ended matches history)
BETSAPI_HISTORY_AUTO_INTERVAL_SECONDS=3600
BETSAPI_HISTORY_DELAY_SECONDS=2.0
RECOMMENDATIONS_BACKFILL_INTERVAL_SECONDS=60
RECOMMENDATIONS_BACKFILL_ACTIVE_LIMIT=300
# Рекомендации: учитывать только матчи за последние N дней. Приоритет короткого окна (неделя/месяц) при достаточных данных.
RECOMMENDATION_LOOKBACK_DAYS=180
RECOMMENDATION_PREFER_RECENT_DAYS=30
# Минимум матчей в лиге у каждого игрока, чтобы использовать статистику по лиге; иначе — по всем лигам.
RECOMMENDATION_MIN_MATCHES_IN_LEAGUE=3
# Догрузка результатов при сбоях: матчи без результата, не более 3 попыток (2ч, 7ч, 24ч от начала)
RESULT_BACKFILL_INTERVAL_SECONDS=120
RESULT_BACKFILL_BATCH_SIZE=10
# Backpressure for normalize queue during history load
BETSAPI_HISTORY_NORMALIZE_QUEUE_MAX_DEPTH=10000
BETSAPI_HISTORY_BACKPRESSURE_SLEEP_SECONDS=0.5

# Enable/disable scheduled collectors (line + live + disappeared + recommendations backfill).
# true = загрузка линии и лайва по расписанию (нужен BETSAPI_TOKEN). false = линия на сайте пустая.
ENABLE_SCHEDULED_COLLECTORS=true
ENABLE_BETSAPI_HISTORY_AUTO=false

# ========== Переменные для фронта (frontend) ==========
# Задаются в frontend/.env.local или при сборке (docker-compose передаёт свои).
# На продакшене на одном домене (pingwin.pro) NEXT_PUBLIC_API_URL и NEXT_PUBLIC_WS_URL не задавать —
# фронт использует тот же домен (/api/v1/* и /ws через nginx).
# NEXT_PUBLIC_API_URL=
# NEXT_PUBLIC_WS_URL=
# Telegram-бот для виджета входа и привязки (без @)
# NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=pingwinbetsbot
# Ссылка на бота для регистрации (t.me/BOT?start=register)
# NEXT_PUBLIC_TELEGRAM_BOT_LINK=https://t.me/pingwinbetsbot?start=register

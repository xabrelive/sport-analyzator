# Куда проксировать запросы /api/* (только для сервера Next.js при npm run dev).
# Если бэкенд запущен на другом порту — укажите его:
# BACKEND_PORT=12000
# или полный URL:
# BACKEND_URL=http://localhost:12000
#
# По умолчанию используется http://localhost:12000
#
# Доступ по LAN (с другого устройства): при сборке фронта в Docker задайте свой IP;
# в браузере API/WS обычно берутся с window.location.hostname — на бэкенде задайте CORS_EXTRA_ORIGINS в .env.
# NEXT_PUBLIC_API_URL=http://192.168.31.130:12000
# NEXT_PUBLIC_WS_URL=ws://192.168.31.130:12000/ws
#
# Продакшен на одном домене (например pingwin.pro): NEXT_PUBLIC_WS_URL и NEXT_PUBLIC_API_URL не задавать —
# фронт использует тот же домен (/api/v1/* и /ws). Nginx (или другой прокси) должен проксировать
# /api/ и /ws на бэкенд (см. docs/nginx-pingwin.example.conf).

# API: не задавать = запросы идут на тот же домен (/api/v1/...), прокси через Next (pingwin.pro).
# Для локальной разработки с отдельным бэкендом можно задать:
# NEXT_PUBLIC_API_URL=http://localhost:11001
# BACKEND_URL=http://localhost:11001

# Telegram Login Widget (имя бота без @)
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=pingwinbetsbot

# Ссылка на бота для регистрации
NEXT_PUBLIC_TELEGRAM_BOT_LINK=https://t.me/pingwinbetsbot

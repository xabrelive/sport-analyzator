# Docker Compose: Postgres и Backend
# Скопируйте в .env в корне проекта (рядом с docker-compose.yml).

# --- PostgreSQL (сервис postgres) ---
POSTGRES_USER=pingwin
POSTGRES_PASSWORD=pingwin
POSTGRES_DB=pingwin

# --- Backend: база данных ---
DATABASE_URL=postgresql://pingwin:pingwin@localhost:11002/pingwin
# ML-база (Elo, фичи, модели). Должна быть отдельная БД pingwin_ml!
DATABASE_URL_ML=postgresql://pingwin:pingwin@localhost:11002/pingwin_ml
# DATABASE_URL_ASYNC=  # опционально, иначе из DATABASE_URL подставляется asyncpg

# --- Backend: auth ---
SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- Backend: коды верификации (срок действия) ---
VERIFICATION_CODE_LENGTH=6
VERIFICATION_CODE_EXPIRE_MINUTES_TELEGRAM=10
VERIFICATION_CODE_EXPIRE_MINUTES_EMAIL=120

# --- Backend: frontend ---
FRONTEND_URL=http://localhost:11000
FRONTEND_PUBLIC_URL=https://pingwin.pro

# --- Backend: CORS и API ---
CORS_EXTRA_ORIGINS=
API_V1_PREFIX=/api/v1
DEBUG=false

# --- BetsAPI (настольный теннис) ---
BETSAPI_TOKEN=
BETSAPI_TABLE_TENNIS_SPORT_ID=92
# Опрос линии (список матчей), секунды (например раз в 5 мин = 300)
BETSAPI_TABLE_TENNIS_LINE_INTERVAL_SEC=300
# Опрос коэффициентов по матчам, где кф ещё нет, секунды (например раз в 5 мин = 300)
BETSAPI_TABLE_TENNIS_ODDS_INTERVAL_SEC=300
BETSAPI_TABLE_TENNIS_MAX_PAGES=20
 # Опрос лайв-событий (inplay), секунды (напр. 5–10)
BETSAPI_TABLE_TENNIS_LIVE_INTERVAL_SEC=5
# Матчи с прематч‑прогнозом: частый апдейт текущего счёта
BETSAPI_TABLE_TENNIS_LIVE_INTERVAL_FORECAST_SEC=4
# Матчи без прогноза: более редкий апдейт текущего счёта
BETSAPI_TABLE_TENNIS_LIVE_INTERVAL_OTHER_SEC=12
 # Проверка результатов (1ч и 3ч после начала), секунды (по умолчанию 30 мин = 1800)
BETSAPI_TABLE_TENNIS_RESULT_CHECK_INTERVAL_SEC=1800
 # Синхронизация результатов из архива (текущий + предыдущий день), секунды
BETSAPI_TABLE_TENNIS_ARCHIVE_SYNC_INTERVAL_SEC=300
 # Перепроверка cancelled матчей с прогнозом, секунды
BETSAPI_TABLE_TENNIS_CANCEL_FORECAST_RECHECK_INTERVAL_SEC=120
# Помечать матч cancelled при исчезновении из линии только если старт в ближайшее время
BETSAPI_TABLE_TENNIS_CANCEL_MISSING_HORIZON_MINUTES=90
 # Задержка перед расчётом прематч‑прогноза (минуты) после появления матча в линии
BETSAPI_TABLE_TENNIS_FORECAST_DELAY_MINUTES=5
 # Минимальный коэффициент для прематч‑прогноза (если кф выбранной стороны ниже — прогноз не строим)
BETSAPI_TABLE_TENNIS_MIN_ODDS_FOR_FORECAST=1.4
# V2 loops и KPI target'ы
BETSAPI_TABLE_TENNIS_V2_FEATURES_INTERVAL_SEC=300
BETSAPI_TABLE_TENNIS_V2_FORECAST_INTERVAL_SEC=60
BETSAPI_TABLE_TENNIS_V2_RESULT_PRIORITY_INTERVAL_SEC=20
BETSAPI_TABLE_TENNIS_V2_KPI_GUARD_INTERVAL_SEC=60
BETSAPI_TABLE_TENNIS_V2_FORECAST_BATCH_SIZE=400
BETSAPI_TABLE_TENNIS_V2_TARGET_HIT_RATE=75
BETSAPI_TABLE_TENNIS_V2_TARGET_PICKS_PER_DAY=300
BETSAPI_TABLE_TENNIS_V2_MIN_CONFIDENCE_FLOOR=62
BETSAPI_TABLE_TENNIS_V2_MIN_CONFIDENCE_CEILING=86
BETSAPI_TABLE_TENNIS_V2_BASE_MIN_CONFIDENCE=70
BETSAPI_TABLE_TENNIS_V2_MIN_EDGE_FLOOR=1.2
BETSAPI_TABLE_TENNIS_V2_MIN_EDGE_CEILING=8
BETSAPI_TABLE_TENNIS_V2_BASE_MIN_EDGE=2.5
TABLE_TENNIS_MATCH_SETS_TO_WIN=3

# --- Разделение API и воркеров (для 100-300 пользователей) ---
# RUN_BACKGROUND_WORKERS=false — backend только API (быстро). Воркеры в tt_workers.
# RUN_BACKGROUND_WORKERS=true — всё в одном (по умолчанию для обратной совместимости).
# RUN_BACKGROUND_WORKERS=

# --- Очередь и воркеры линии (масштабирование при росте объёма) ---
LINE_QUEUE_MAXSIZE=32
LINE_WORKER_COUNT=3
LINE_SSE_INTERVAL_SEC=5

# --- ML (XGBoost/LightGBM GPU) ---
# ML_USE_GPU=false — принудительно CPU (Docker без --gpus, или nvidia-smi недоступен)
ML_USE_GPU=true
# ml_sync_loop: интервал подтяжки main→ML и переобучения (сек). 0 = отключено. 600 = 10 мин.
ML_SYNC_INTERVAL_SEC=600
# Полная синхронизация: days_back=0 весь архив, иначе N дней назад
ML_SYNC_DAYS_BACK=0
ML_SYNC_BATCH_SIZE=15000
ML_BACKFILL_WORKERS=16
ML_RETRAIN_MIN_NEW_MATCHES=50

# --- SMTP (отправка кодов на почту). Пример для Mail.ru (порт 465 SSL) ---
# Для Mail.ru: пароль приложения в настройках безопасности.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# --- Telegram Bot (код для регистрации). Токен должен совпадать с frontend ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_SIGNALS_FREE_CHAT_ID=-1001642470199
TELEGRAM_SIGNALS_VIP_CHAT_ID=-1001975944266
TELEGRAM_CHANNELS_LOOP_INTERVAL_SEC=60
TELEGRAM_URGENT_LEAD_MINUTES=30
TELEGRAM_FREE_WINDOW_START_HOUR=9
TELEGRAM_FREE_WINDOW_END_HOUR=19
TELEGRAM_FREE_DAILY_POSTS=3
TELEGRAM_FREE_MIN_LEAD_MINUTES=60
TELEGRAM_VIP_HOURLY_MIN=3
TELEGRAM_VIP_HOURLY_MAX=4

# --- User notifications ---
NOTIFICATIONS_BATCH_INTERVAL_MINUTES=30
NOTIFICATIONS_LOOP_INTERVAL_SEC=60

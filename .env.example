# Docker Compose: Postgres и Backend
# Скопируйте в .env в корне проекта (рядом с docker-compose.yml).

# --- PostgreSQL (сервис postgres) ---
POSTGRES_USER=pingwin
POSTGRES_PASSWORD=pingwin
POSTGRES_DB=pingwin

# --- Backend: база данных ---
DATABASE_URL=postgresql://pingwin:pingwin@localhost:11002/pingwin
# ML-база (Elo, фичи, модели). Должна быть отдельная БД pingwin_ml!
DATABASE_URL_ML=postgresql://pingwin:pingwin@localhost:11002/pingwin_ml
# DATABASE_URL_ASYNC=  # опционально, иначе из DATABASE_URL подставляется asyncpg
# Пул соединений к основной БД (при большом числе воркеров/SSE можно увеличить)
# DB_POOL_SIZE=20
# DB_POOL_MAX_OVERFLOW=20
# DB_POOL_RECYCLE_SEC=300

# --- Backend: auth ---
SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- Backend: коды верификации (срок действия) ---
VERIFICATION_CODE_LENGTH=6
VERIFICATION_CODE_EXPIRE_MINUTES_TELEGRAM=10
VERIFICATION_CODE_EXPIRE_MINUTES_EMAIL=120

# --- Backend: frontend ---
FRONTEND_URL=http://localhost:11000
FRONTEND_PUBLIC_URL=https://pingwin.pro

# --- Backend: CORS и API ---
CORS_EXTRA_ORIGINS=
API_V1_PREFIX=/api/v1
DEBUG=false

# --- BetsAPI (настольный теннис) ---
BETSAPI_TOKEN=
BETSAPI_TABLE_TENNIS_SPORT_ID=92
# Опрос линии (список матчей), секунды (например раз в 5 мин = 300)
BETSAPI_TABLE_TENNIS_LINE_INTERVAL_SEC=300
# Опрос коэффициентов по матчам, где кф ещё нет, секунды (например раз в 5 мин = 300)
BETSAPI_TABLE_TENNIS_ODDS_INTERVAL_SEC=300
BETSAPI_TABLE_TENNIS_MAX_PAGES=20
 # Опрос лайв-событий (inplay), секунды (напр. 5–10)
BETSAPI_TABLE_TENNIS_LIVE_INTERVAL_SEC=5
# Матчи с прематч‑прогнозом: частый апдейт текущего счёта
BETSAPI_TABLE_TENNIS_LIVE_INTERVAL_FORECAST_SEC=4
# Матчи без прогноза: более редкий апдейт текущего счёта
BETSAPI_TABLE_TENNIS_LIVE_INTERVAL_OTHER_SEC=12
 # Проверка результатов (1ч и 3ч после начала), секунды (по умолчанию 30 мин = 1800)
BETSAPI_TABLE_TENNIS_RESULT_CHECK_INTERVAL_SEC=1800
 # Синхронизация результатов из архива (текущий + предыдущий день), секунды
BETSAPI_TABLE_TENNIS_ARCHIVE_SYNC_INTERVAL_SEC=300
 # Перепроверка cancelled матчей с прогнозом, секунды
BETSAPI_TABLE_TENNIS_CANCEL_FORECAST_RECHECK_INTERVAL_SEC=120
# Помечать матч cancelled при исчезновении из линии только если старт в ближайшее время
BETSAPI_TABLE_TENNIS_CANCEL_MISSING_HORIZON_MINUTES=90
 # Задержка перед расчётом прематч‑прогноза (минуты) после появления матча в линии
BETSAPI_TABLE_TENNIS_FORECAST_DELAY_MINUTES=5
BETSAPI_TABLE_TENNIS_FORECAST_TARGET_MINUTES_BEFORE=60
BETSAPI_TABLE_TENNIS_FORECAST_TOLERANCE_MINUTES=5
# ML-прогнозы: только матчи, до начала которых 1 час и менее (окно 1–60 мин до старта).
BETSAPI_TABLE_TENNIS_FORECAST_WINDOW_MIN_MINUTES_BEFORE=1
BETSAPI_TABLE_TENNIS_FORECAST_ML_MAX_MINUTES_BEFORE=60
# Минимальный коэффициент для прематч‑прогноза (если кф выбранной стороны ниже — прогноз не строим)
BETSAPI_TABLE_TENNIS_MIN_ODDS_FOR_FORECAST=1.4
# No-ML прогнозы: матчи, до начала которых 2 часа и менее (окно 1–120 мин до старта).
BETSAPI_TABLE_TENNIS_NO_ML_FORECAST_MIN_MINUTES_AHEAD=1
BETSAPI_TABLE_TENNIS_NO_ML_FORECAST_MAX_HOURS_AHEAD=2
# No-ML: для этих лиг инвертируем выбор (П1↔П2: матч и 1-й сет). Setka Cup, Сетка Кап и др. Через запятую, подстрока в league_name.
BETSAPI_TABLE_TENNIS_NO_ML_INVERT_PICK_LEAGUE_NAMES=Czech Liga Pro,TT cup,Setka Cup,Сетка Кап
# Лиги, для которых no_ML прогноз не выдаём (низкий %). Через запятую, подстрока в названии лиги.
# BETSAPI_TABLE_TENNIS_NO_ML_EXCLUDE_LEAGUE_NAMES=Сетка кап,Другая лига
# V2 loops и KPI target'ы
# Раннее сканирование линии (Stage 1), секунды (по умолчанию 600 = 10 мин)
BETSAPI_TABLE_TENNIS_EARLY_SCAN_INTERVAL_SEC=600
BETSAPI_TABLE_TENNIS_V2_FEATURES_INTERVAL_SEC=300
# ML-прогнозы: интервал цикла (сек). 60 = раз в минуту
BETSAPI_TABLE_TENNIS_V2_FORECAST_INTERVAL_SEC=60
# NN-прогнозы: интервал цикла (сек). 60 = раз в минуту
BETSAPI_TABLE_TENNIS_NN_FORECAST_INTERVAL_SEC=60
# no_ML прогнозы: интервал цикла (сек). 180 = раз в 3 минуты
BETSAPI_TABLE_TENNIS_NO_ML_FORECAST_INTERVAL_SEC=60
BETSAPI_TABLE_TENNIS_V2_RESULT_PRIORITY_INTERVAL_SEC=20
BETSAPI_TABLE_TENNIS_V2_KPI_GUARD_INTERVAL_SEC=60
BETSAPI_TABLE_TENNIS_V2_FORECAST_BATCH_SIZE=400
BETSAPI_TABLE_TENNIS_V2_TARGET_HIT_RATE=75
BETSAPI_TABLE_TENNIS_V2_TARGET_PICKS_PER_DAY=300
# Игрок в приоритете. Выше пороги — меньше прогнозов, только уверенные (P >= 65–68%).
BETSAPI_TABLE_TENNIS_V2_MIN_CONFIDENCE_FLOOR=60
BETSAPI_TABLE_TENNIS_V2_MIN_CONFIDENCE_CEILING=86
BETSAPI_TABLE_TENNIS_V2_BASE_MIN_CONFIDENCE=68
BETSAPI_TABLE_TENNIS_V2_MIN_EDGE_FLOOR=0
BETSAPI_TABLE_TENNIS_V2_MIN_EDGE_CEILING=8
BETSAPI_TABLE_TENNIS_V2_BASE_MIN_EDGE=0
# Quality-first paid ML profile (fewer but stronger signals):
BETSAPI_TABLE_TENNIS_V2_PREFERRED_MIN_ODDS=1.75
BETSAPI_TABLE_TENNIS_V2_ALLOW_SOFT_FALLBACK=false
# false = не брать «лучший по уверенности», если нет пика с высоким P — прогноз не даём (только уверенные).
BETSAPI_TABLE_TENNIS_V2_ALLOW_HARD_CONFIDENCE_FALLBACK=false
# Публикуем только если P >= этого % (68 = меньше прогнозов, выше точность).
BETSAPI_TABLE_TENNIS_V2_MIN_CONFIDENCE_TO_PUBLISH=68
# Порог публикации нейросети (NN канал).
BETSAPI_TABLE_TENNIS_NN_MIN_CONFIDENCE_TO_PUBLISH=62
BETSAPI_TABLE_TENNIS_NN_MIN_MATCH_CONFIDENCE_PCT=66
BETSAPI_TABLE_TENNIS_NN_MIN_SET1_CONFIDENCE_PCT=67
BETSAPI_TABLE_TENNIS_V2_PRIORITIZE_QUALITY_OVER_VOLUME=true
# Доп. порог в селекторе: только кандидаты с P >= этого % (65 = только уверенные).
BETSAPI_TABLE_TENNIS_V2_CONFIDENCE_FILTER_MIN_PCT=65

# Train-time quality filters for stronger TT signal:
# Exclude cold-start rows. require_h2h=false — больше данных (рекомендуется для лучшего test logloss).
ML_V2_TRAIN_MIN_MATCHES_PLAYED_BEFORE=10
ML_V2_TRAIN_REQUIRE_H2H=false
# Топ-K фичей по |corr| с target (0 = все). 50 — меньше шума, тест logloss чуть выше.
# ML_V2_TOP_K_FEATURES=0
# Chaos leagues: матчи из лиг с league_upset_rate > порога исключаются из обучения (0.45 = только стабильные лиги).
ML_V2_TRAIN_MAX_LEAGUE_UPSET_RATE=0.45
# 4 модели по опыту: rookie (<20 матчей), low (20–79), mid (80–299), pro (≥300). routing = max(p1_exp_bucket, p2_exp_bucket).
# true = обучать tt_ml_v2_b1..b4_*; инференс подхватывает bucket-модели при наличии файлов (без доп. флага).
ML_V2_USE_EXPERIENCE_REGIMES=true
ML_V2_EXPERIENCE_REGIME_MIN_TRAIN=500
ML_V2_ENABLE_NN=true
ML_V2_NN_HIDDEN_LAYERS=128,64
ML_V2_NN_LEARNING_RATE=0.001
ML_V2_NN_ALPHA=0.0001
ML_V2_NN_BATCH_SIZE=256
ML_V2_NN_MAX_ITER=120
# Disable time-of-day features to avoid league/time artifacts ("clock leakage").
ML_V2_DISABLE_CLOCK_FEATURES=true
# Модель не использует линию (кэф): только сила/форма игроков. Кэф не главный фактор отбора.
ML_V2_DISABLE_MARKET_FEATURES=true
# target_match: текущие дефолты дают test raw_logloss ~0.676 (150/20, reg 0.3/1.0). При переобучении — увеличить reg.
# ML_V2_LGB_NUM_LEAVES_MATCH=150
# ML_V2_LGB_MIN_CHILD_MATCH=20
# ML_V2_LGB_REG_ALPHA_MATCH=0.3
# ML_V2_LGB_REG_LAMBDA_MATCH=1.0
# target_set1: без ограничений val logloss взлетает до 13+, отдельная регуляризация.
# ML_V2_LGB_NUM_LEAVES_SET1=96
# ML_V2_LGB_MIN_CHILD_SET1=30
# ML_V2_LGB_REG_ALPHA_SET1=0.7
# ML_V2_LGB_REG_LAMBDA_SET1=1.8
# Клип фичей по квантилям (0.01 = 1%/99%). Меньше — меньше обрезка, больше сигнала.
# ML_V2_FEATURE_CLIP_QUANTILE=0.01
# player_daily_stats auto-backfill per sync cycle (from ml.player_match_stats)
ML_V2_PLAYER_DAILY_BACKFILL_LIMIT=50000
TABLE_TENNIS_MATCH_SETS_TO_WIN=3

# --- Разделение API и воркеров (для 100-300 пользователей) ---
# RUN_BACKGROUND_WORKERS=false — backend только API (быстро). Воркеры в tt_workers.
# RUN_BACKGROUND_WORKERS=true — всё в одном (по умолчанию).
RUN_BACKGROUND_WORKERS=true

# --- Очередь и воркеры линии (масштабирование при росте объёма) ---
LINE_QUEUE_MAXSIZE=32
LINE_WORKER_COUNT=3
LINE_SSE_INTERVAL_SEC=5

# --- ML (XGBoost/LightGBM GPU) ---
# ML engine: v1 (legacy postgres ML) | v2 (ClickHouse-first)
ML_ENGINE=v2
# ClickHouse for ML v2
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=11003
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=ml
# ML_USE_GPU=false — принудительно CPU (Docker без --gpus, или nvidia-smi недоступен)
ML_USE_GPU=true
# Какой GPU использовать (только в Docker с nvidia). all = все, 0 = первая карта, 1 = вторая
# NVIDIA_VISIBLE_DEVICES=all
# Каталог для сохранения моделей (в Docker задаётся в compose, локально например /tmp/pingwin_ml_models)
ML_MODEL_DIR=/app/ml_models
# ml_sync_loop: интервал подтяжки main→ML и переобучения (сек). 0 = отключено. 600 = 10 мин.
# Интервал автозаполнения всех ML таблиц (sync + backfill фичей). 600 = каждые 10 мин.
ML_SYNC_INTERVAL_SEC=600
# true = подтяжку выполняет только сервис ml_sync (отдельный контейнер). false = цикл в tt_workers.
ML_SYNC_STANDALONE=true
# Автопереобучение модели: раз в N секунд (1800 = 30 мин). Задачу выполняет ml_worker (GPU).
ML_RETRAIN_INTERVAL_SEC=1800
# Полная синхронизация: days_back=0 весь архив, иначе N дней назад
ML_SYNC_DAYS_BACK=0
ML_SYNC_BATCH_SIZE=15000
# Параллельных воркеров при расчёте фичей (backfill)
ML_BACKFILL_WORKERS=16
ML_RETRAIN_MIN_NEW_MATCHES=50
ML_RETRAIN_INTERVAL_SEC=1800
# Временной сплит: 2016 warmup, 2017–2022 train, 2023–2024 val.
ML_TRAIN_YEAR_START=2017
ML_TRAIN_YEAR_END=2022
# Макс. строк в выборке для обучения (по годам выше). 0 = безлимит (все матчи за годы)
ML_TRAIN_LIMIT=0
# Макс. строк (сетов) для set/p_point. 0 = безлимит (все сеты за годы)
ML_TRAIN_SET_LIMIT=0
ML_WARMUP_YEAR_END=2016
# Валидация: годы и макс. строк (матчей) для оценки модели
ML_VAL_YEAR_START=2023
ML_VAL_YEAR_END=2024
ML_VAL_LIMIT=100000
# Фильтр по кф при обучении (0 = выкл): 1.4–3.0 — не только фавориты
# ML_TRAIN_ODDS_MIN=1.4
# ML_TRAIN_ODDS_MAX=3.0
# Ансамбль: P_final = ML_ENSEMBLE_ELO_WEIGHT * P_elo + (1 - ...) * P_ml
ML_ENSEMBLE_ELO_WEIGHT=0.35
# LightGBM: early stopping (0 = выкл). 300 = останов, если valid logloss не улучшается 300 раундов
ML_LGB_EARLY_STOPPING_ROUNDS=300

# --- SMTP (отправка кодов на почту). Пример для Mail.ru (порт 465 SSL) ---
# Для Mail.ru: пароль приложения в настройках безопасности.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# --- Telegram Bot (код для регистрации). Токен должен совпадать с frontend ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_SIGNALS_FREE_CHAT_ID=-1001642470199
TELEGRAM_SIGNALS_VIP_CHAT_ID=-1001975944266
# Публичная ссылка на VIP-канал (для проверки доступа по подписке)
# TELEGRAM_SIGNALS_VIP_PUBLIC_URL=https://t.me/your_vip_channel
# paid ML channel (историческое имя vip_* в переменных)
TELEGRAM_SIGNALS_NO_ML_CHAT_ID=
TELEGRAM_SIGNALS_FREE_BOT_TOKEN=
TELEGRAM_SIGNALS_VIP_BOT_TOKEN=
TELEGRAM_SIGNALS_NO_ML_BOT_TOKEN=
TELEGRAM_CHANNELS_LOOP_INTERVAL_SEC=60
TELEGRAM_URGENT_LEAD_MINUTES=30
TELEGRAM_FREE_WINDOW_START_HOUR=9
TELEGRAM_FREE_WINDOW_END_HOUR=19
TELEGRAM_FREE_DAILY_POSTS=3
TELEGRAM_FREE_MIN_LEAD_MINUTES=60
TELEGRAM_VIP_HOURLY_MIN=3
TELEGRAM_VIP_HOURLY_MAX=4
# Интервал проверки доступа к VIP-каналу (сек). По умолчанию 600 = 10 мин.
VIP_ACCESS_CHECK_INTERVAL_SEC=600

# --- User notifications ---
NOTIFICATIONS_BATCH_INTERVAL_MINUTES=30
NOTIFICATIONS_LOOP_INTERVAL_SEC=20
NOTIFICATIONS_IMMEDIATE_AFTER_FORECAST_SEC=0
NOTIFICATIONS_NEW_FORECAST_BATCH_MINUTES=10

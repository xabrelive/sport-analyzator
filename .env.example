# Database
POSTGRES_USER=sport
POSTGRES_PASSWORD=sport
POSTGRES_DB=sport_analyzator
DATABASE_URL=postgresql://sport:sport@localhost:11002/sport_analyzator

# Redis
REDIS_URL=redis://localhost:11003/0

# Backend
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ADMIN_SECRET=
API_V1_PREFIX=/api/v1
DEBUG=1
# For email verification link (e.g. https://your-frontend.vercel.app)
FRONTEND_URL=http://localhost:11000

# Data providers (get keys from dashboards)
SPORTRADAR_API_KEY=
SPORTMONKS_API_KEY=
THE_ODDS_API_KEY=
# BetsAPI — настольный теннис: https://betsapi.com/c/table-tennis/
# Токен купить/включить: https://betsapi.com/mm/orders (лимит 3600 запросов/час)
BETSAPI_TOKEN=
BETSAPI_TABLE_TENNIS_SPORT_ID=92
# Сколько матчей за цикл запрашивать коэффициенты (1 запрос на матч). Лимит 3600/час.
BETSAPI_MAX_EVENTS_FOR_ODDS=50

# Telegram (bot for registration + Login Widget; same token)
TELEGRAM_BOT_TOKEN=
TELEGRAM_SIGNALS_CHAT_ID=
# Bot username for Login Widget (e.g. PingWinBot) — set domain in @BotFather /setdomain
# Frontend: set in frontend/.env.local — NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=PingWinBot, NEXT_PUBLIC_TELEGRAM_BOT_LINK=https://t.me/PingWinBot?start=register

# Probability / Value
VALUE_EV_THRESHOLD=0.05
MIN_ODDS=1.01
MAX_ODDS=50.0

# Frontend (Next.js): куда проксировать /api/*. При локальном запуске фронта (npm run dev):
# — если бэкенд на порту 11001: ничего не задавать или BACKEND_URL=http://localhost:11001
# — если бэкенд на другом порту: BACKEND_PORT=11001 или BACKEND_URL=http://localhost:11001
# В Docker фронт использует BACKEND_URL=http://backend:11001 из docker-compose.
# BACKEND_PORT=
# BACKEND_URL=http://localhost:11001

# Polling (seconds). Live list every 2–3s for real-time set score; live odds every 30s for fresher coefficients.
LIVE_POLL_INTERVAL_SECONDS=3
LIVE_ODDS_POLL_INTERVAL_SECONDS=30
PREMATCH_POLL_INTERVAL_SECONDS=600

# ML engine: v1 (legacy postgres ML) | v2 (ClickHouse-first)
ML_ENGINE=v2
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=11003
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=ml
# Docker Compose: Postgres и Backend

# --- PostgreSQL (сервис postgres) ---
POSTGRES_USER=pingwin
POSTGRES_PASSWORD=pingwin
POSTGRES_DB=pingwin

# --- Backend: база данных ---
DATABASE_URL=postgresql://pingwin:pingwin@localhost:11002/pingwin
# ML-база (Elo, фичи, сигналы, подозрительные матчи)
DATABASE_URL_ML=postgresql://pingwin:pingwin@localhost:11002/pingwin_ml
# DATABASE_URL_ASYNC=  # опционально, иначе из DATABASE_URL подставляется asyncpg
# Пул соединений к основной БД (при большом числе воркеров/SSE можно увеличить)
# DB_POOL_SIZE=20
# DB_POOL_MAX_OVERFLOW=20
# DB_POOL_RECYCLE_SEC=300

# --- Backend: auth ---
SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- Backend: коды верификации (срок действия) ---
VERIFICATION_CODE_LENGTH=6
VERIFICATION_CODE_EXPIRE_MINUTES_TELEGRAM=10
VERIFICATION_CODE_EXPIRE_MINUTES_EMAIL=120

# --- Backend: frontend ---
FRONTEND_URL=http://localhost:11000
FRONTEND_PUBLIC_URL=https://pingwin.pro

# --- Backend: CORS и API ---
CORS_EXTRA_ORIGINS=
API_V1_PREFIX=/api/v1
DEBUG=false

# --- BetsAPI (настольный теннис) ---
BETSAPI_TOKEN=247117-YgC9zBuGBnHrQh
BETSAPI_TABLE_TENNIS_SPORT_ID=92
# Опрос линии (список матчей), сек. Например раз в 5 мин = 300
BETSAPI_TABLE_TENNIS_LINE_INTERVAL_SEC=420
# Опрос коэффициентов по матчам без кф, сек. Например раз в 5 мин = 300
BETSAPI_TABLE_TENNIS_ODDS_INTERVAL_SEC=300
# Опрос лайв-событий (inplay), сек. Для почти-реального времени можно 5–10
BETSAPI_TABLE_TENNIS_LIVE_INTERVAL_SEC=8
BETSAPI_TABLE_TENNIS_LIVE_INTERVAL_FORECAST_SEC=4
BETSAPI_TABLE_TENNIS_LIVE_INTERVAL_OTHER_SEC=12
# Проверка результатов (1ч и 3ч после начала), сек. По умолчанию 30 мин = 1800
BETSAPI_TABLE_TENNIS_RESULT_CHECK_INTERVAL_SEC=1800
BETSAPI_TABLE_TENNIS_ARCHIVE_SYNC_INTERVAL_SEC=300
BETSAPI_TABLE_TENNIS_CANCEL_FORECAST_RECHECK_INTERVAL_SEC=120
BETSAPI_TABLE_TENNIS_CANCEL_MISSING_HORIZON_MINUTES=90
BETSAPI_TABLE_TENNIS_MAX_PAGES=50
# Задержка перед расчётом прематч‑прогноза (минуты) после появления матча в линии
BETSAPI_TABLE_TENNIS_FORECAST_DELAY_MINUTES=5
BETSAPI_TABLE_TENNIS_FORECAST_TARGET_MINUTES_BEFORE=60
BETSAPI_TABLE_TENNIS_FORECAST_TOLERANCE_MINUTES=5
# ML: прогнозы только для матчей до начала которых 1 час и менее (1–60 мин до старта).
BETSAPI_TABLE_TENNIS_FORECAST_WINDOW_MIN_MINUTES_BEFORE=1
BETSAPI_TABLE_TENNIS_FORECAST_ML_MAX_MINUTES_BEFORE=60
# Минимальный коэффициент для прематч‑прогноза (если кф выбранной стороны ниже — прогноз не строим)
BETSAPI_TABLE_TENNIS_MIN_ODDS_FOR_FORECAST=1.4
# No-ML: прогнозы для матчей до начала которых 2 часа и менее (1–120 мин до старта).
BETSAPI_TABLE_TENNIS_NO_ML_FORECAST_MIN_MINUTES_AHEAD=1
BETSAPI_TABLE_TENNIS_NO_ML_FORECAST_MAX_HOURS_AHEAD=2
# Лиги, для которых no_ML инвертирует выбор (П1→П2, П2→П1). Через запятую, подстрока в названии лиги.
# No-ML: для этих лиг инвертируем выбор (П1↔П2 для матча и для 1-го сета). Setka Cup, Сетка Кап и др.
BETSAPI_TABLE_TENNIS_NO_ML_INVERT_PICK_LEAGUE_NAMES=Setka Cup,Сетка Кап
# Лиги, для которых no_ML прогноз не выдаём (низкий %). Через запятую, подстрока в названии лиги.
BETSAPI_TABLE_TENNIS_NO_ML_EXCLUDE_LEAGUE_NAMES=
# Раннее сканирование линии (Stage 1), сек. По умолчанию 600 = 10 мин
BETSAPI_TABLE_TENNIS_EARLY_SCAN_INTERVAL_SEC=600
BETSAPI_TABLE_TENNIS_V2_FEATURES_INTERVAL_SEC=300
# ML-прогнозы: интервал цикла (сек). 60 = раз в минуту
BETSAPI_TABLE_TENNIS_V2_FORECAST_INTERVAL_SEC=60
# NN-прогнозы: интервал цикла (сек). 60 = раз в минуту
BETSAPI_TABLE_TENNIS_NN_FORECAST_INTERVAL_SEC=60
# no_ML прогнозы: интервал цикла (сек). 180 = раз в 3 минуты
BETSAPI_TABLE_TENNIS_NO_ML_FORECAST_INTERVAL_SEC=60
BETSAPI_TABLE_TENNIS_V2_RESULT_PRIORITY_INTERVAL_SEC=20
BETSAPI_TABLE_TENNIS_V2_KPI_GUARD_INTERVAL_SEC=60
BETSAPI_TABLE_TENNIS_V2_FORECAST_BATCH_SIZE=400
BETSAPI_TABLE_TENNIS_V2_TARGET_HIT_RATE=75
BETSAPI_TABLE_TENNIS_V2_TARGET_PICKS_PER_DAY=300
# ML v2: base 60%, publish 60%, filter 65%, floor 55%, hard fallback вкл.
BETSAPI_TABLE_TENNIS_V2_MIN_CONFIDENCE_FLOOR=55
BETSAPI_TABLE_TENNIS_V2_MIN_CONFIDENCE_CEILING=86
BETSAPI_TABLE_TENNIS_V2_BASE_MIN_CONFIDENCE=60
BETSAPI_TABLE_TENNIS_V2_MIN_EDGE_FLOOR=0
BETSAPI_TABLE_TENNIS_V2_MIN_EDGE_CEILING=8
BETSAPI_TABLE_TENNIS_V2_BASE_MIN_EDGE=0
BETSAPI_TABLE_TENNIS_V2_PREFERRED_MIN_ODDS=1.35
BETSAPI_TABLE_TENNIS_V2_ALLOW_SOFT_FALLBACK=true
BETSAPI_TABLE_TENNIS_V2_ALLOW_HARD_CONFIDENCE_FALLBACK=true
BETSAPI_TABLE_TENNIS_V2_MIN_CONFIDENCE_TO_PUBLISH=54
BETSAPI_TABLE_TENNIS_NN_MIN_CONFIDENCE_TO_PUBLISH=55
BETSAPI_TABLE_TENNIS_NN_MIN_MATCH_CONFIDENCE_PCT=59
BETSAPI_TABLE_TENNIS_NN_MIN_SET1_CONFIDENCE_PCT=60
BETSAPI_TABLE_TENNIS_NN_CONFIDENCE_FILTER_MIN_PCT=56
BETSAPI_TABLE_TENNIS_NN_PREFERRED_MIN_ODDS=1.35
BETSAPI_TABLE_TENNIS_V2_PRIORITIZE_QUALITY_OVER_VOLUME=false
BETSAPI_TABLE_TENNIS_V2_CONFIDENCE_FILTER_MIN_PCT=52
BETSAPI_TABLE_TENNIS_V2_EXCLUDE_LEAGUE_NAMES=
BETSAPI_TABLE_TENNIS_NO_ML_CONFIDENCE_THRESHOLD_SET=0.65
BETSAPI_TABLE_TENNIS_NO_ML_CONFIDENCE_THRESHOLD_MATCH=0.65
BETSAPI_TABLE_TENNIS_NO_ML_MIN_MATCHES_FOR_RECOMMENDATION=2
BETSAPI_TABLE_TENNIS_NO_ML_MIN_MATCHES_FOR_MATCH_RECOMMENDATION=4
BETSAPI_TABLE_TENNIS_NO_ML_MIN_CONFIDENCE_MARGIN=0.03
BETSAPI_TABLE_TENNIS_NO_ML_EXCLUDE_LEAGUE_NAMES=

# Train-time quality filters and ML v2 options
ML_V2_TRAIN_MIN_MATCHES_PLAYED_BEFORE=10
# false = больше данных, лучше test logloss (~0.676). true = только матчи с личной встречей.
ML_V2_TRAIN_REQUIRE_H2H=false
# Топ-K фичей по |corr| с target (0 = все). 50 = меньше шума, тест logloss чуть выше.
ML_V2_TOP_K_FEATURES=0
# Chaos leagues: матчи из лиг с league_upset_rate > порога исключаются из обучения (0.45 = только стабильные лиги).
ML_V2_TRAIN_MAX_LEAGUE_UPSET_RATE=0.45
# Experience regimes: 4 модели (rookie/low/mid/pro). Обучаются tt_ml_v2_b1..b4_*; инференс подхватывает их при наличии.
ML_V2_USE_EXPERIENCE_REGIMES=true
ML_V2_EXPERIENCE_REGIME_MIN_TRAIN=500
ML_V2_ENABLE_NN=true
ML_V2_NN_HIDDEN_LAYERS=128,64
ML_V2_NN_LEARNING_RATE=0.001
ML_V2_NN_ALPHA=0.0001
ML_V2_NN_BATCH_SIZE=256
ML_V2_NN_MAX_ITER=120
# Модель не использует линию (кэф): только сила/форма игроков.
ML_V2_DISABLE_MARKET_FEATURES=true
# Временной сплит по годам: train 2016–2023, val 2024, test 2025+
ML_V2_SPLIT_BY_YEAR=true
# LightGBM v2 (общие)
ML_V2_LGB_MIN_CHILD_SAMPLES=20
ML_V2_LGB_LEARNING_RATE=0.02
ML_V2_LGB_NUM_LEAVES=128
# target_match: 150/20 и reg 0.3/1.0 дают test raw_logloss ~0.676
ML_V2_LGB_NUM_LEAVES_MATCH=150
ML_V2_LGB_MIN_CHILD_MATCH=20
ML_V2_LGB_REG_ALPHA_MATCH=0.3
ML_V2_LGB_REG_LAMBDA_MATCH=1.0
# target_set1: отдельная регуляризация (без неё val logloss взлетает)
ML_V2_LGB_NUM_LEAVES_SET1=96
ML_V2_LGB_MIN_CHILD_SET1=30
ML_V2_LGB_REG_ALPHA_SET1=0.7
ML_V2_LGB_REG_LAMBDA_SET1=1.8
# Клип фичей по квантилям (0.01 = 1%/99%)
ML_V2_FEATURE_CLIP_QUANTILE=0.01
# Ансамбль v2: P_final = ML_V2_ENSEMBLE_ELO_WEIGHT * P_elo + (1 - ...) * P_ml
ML_V2_ENSEMBLE_ELO_WEIGHT=0.3
ML_V2_DISABLE_CLOCK_FEATURES=true
ML_V2_PLAYER_DAILY_BACKFILL_LIMIT=50000
# ML v2: батчей «missing» фичей за один цикл sync (0 = выкл). 4 = догнать пропуски быстрее.
ML_V2_MISSING_BACKFILL_PASSES_PER_CYCLE=4
# Размер одного батча missing backfill в v2 (матчей за проход).
ML_V2_MISSING_BACKFILL_LIMIT=25000
# Размер порции авто-refresh исторических фич при смене схемы фичей.
ML_V2_REFRESH_BACKFILL_LIMIT=20000
TABLE_TENNIS_MATCH_SETS_TO_WIN=3

# --- Разделение API и воркеров (для 100-300 пользователей) ---
# RUN_BACKGROUND_WORKERS=false — backend только API (быстро). Воркеры в tt_workers.
# RUN_BACKGROUND_WORKERS=true — всё в одном (по умолчанию).
RUN_BACKGROUND_WORKERS=true

# --- ML pipeline (pingwin_ml, XGBoost/LightGBM, GPU) ---
# ML_USE_GPU=false — принудительно CPU (Docker без --gpus, или nvidia-smi недоступен)
ML_USE_GPU=true
# Какой GPU использовать (только в Docker с nvidia). all = все, 0 = первая карта, 1 = вторая
# NVIDIA_VISIBLE_DEVICES=all
# Каталог для сохранения моделей (в Docker задаётся в compose, локально например /tmp/pingwin_ml_models)
ML_MODEL_DIR=/tmp/pingwin_ml_models
# ml_sync_loop: интервал подтяжки main→ML (сек). 0 = отключено. 600 = 10 мин.
ML_SYNC_INTERVAL_SEC=600
# true = подтяжку выполняет только сервис ml_sync (не зависит от API/воркеров)
ML_SYNC_STANDALONE=true
ML_RETRAIN_MIN_NEW_MATCHES=40
# Автопереобучение модели: раз в N секунд (1800 = 30 мин). Задачу выполняет ml_worker (GPU).
ML_RETRAIN_INTERVAL_SEC=1800
# Полная синхронизация: days_back=0 весь архив, иначе N дней назад
ML_SYNC_DAYS_BACK=0
ML_SYNC_BATCH_SIZE=3000
# Параллельных воркеров при расчёте фичей (backfill). Больше = быстрее догрузка в ML
ML_BACKFILL_WORKERS=16
# false = считать калибровку и p_point (модель точнее). true = только LightGBM на GPU.
ML_GPU_ONLY=false
# Временной сплит: 2016 warmup, 2017–2026 train (дообучение каждые 30 мин), val — следующий год.
ML_TRAIN_YEAR_START=2017
ML_TRAIN_YEAR_END=2022
# Макс. строк в выборке для обучения (по годам выше). 0 = безлимит (все матчи за годы)
ML_TRAIN_LIMIT=0
# Макс. строк (сетов) для set/p_point. 0 = безлимит (все сеты за годы)
ML_TRAIN_SET_LIMIT=0
ML_WARMUP_YEAR_END=2016
# Валидация: годы и макс. строк (матчей) для оценки модели
ML_VAL_YEAR_START=2023
ML_VAL_YEAR_END=2024
ML_VAL_LIMIT=100000
# 0 = все матчи в обучении; 20+ = только с достаточной историей
ML_TRAIN_MIN_SAMPLE_SIZE=0
# Фильтр по кф при обучении (0 = выкл): 1.4–3.0 — не только фавориты
# ML_TRAIN_ODDS_MIN=1.4
# ML_TRAIN_ODDS_MAX=3.0
# Ансамбль: P_final = ML_ENSEMBLE_ELO_WEIGHT * P_elo + (1 - ...) * P_ml
ML_ENSEMBLE_ELO_WEIGHT=0.35
# LightGBM: early stopping (0 = выкл). 500 = больше итераций, лучше сходимость v2 (val logloss ~0.68)
ML_LGB_EARLY_STOPPING_ROUNDS=500

# --- Очередь и воркеры линии (масштабирование при росте объёма) ---
LINE_QUEUE_MAXSIZE=32
LINE_WORKER_COUNT=3
LINE_SSE_INTERVAL_SEC=5


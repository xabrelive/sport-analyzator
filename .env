SMTP_PORT=465
SMTP_USER=no-reply@pingwin.pro
SMTP_PASSWORD=wxG4paKLaGSDqBH0q4zh
SMTP_FROM_EMAIL=no-reply@pingwin.pro
SMTP_USE_TLS=true
SMTP_USE_SSL=true

